# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Use sslmode=verify-full for Neon (it presents a valid cert). The older
# value `sslmode=require` still works but is deprecated by pg and prints a
# warning at startup.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="replace-with-a-32-byte-random-secret"

# Optional — Google OAuth. Leave unset to hide the "Sign in with Google" button.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for absolute links in emails and OAuth callbacks.
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (transactional email) ────────────────────────────────────────────
# Optional — without RESEND_API_KEY emails are logged to the console (no-op).
RESEND_API_KEY=""
RESEND_FROM="Glaze Studio <noreply@yourdomain.com>"

# ─── Cron secret (Vercel Cron) ───────────────────────────────────────────────
# Optional but recommended in production. When set, /api/cron/* require
# Authorization: Bearer <CRON_SECRET>. Vercel Cron sends this automatically.
CRON_SECRET="replace-with-a-32-byte-random-secret"
